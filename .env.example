# Configuration du LLM — copie ce fichier en .env (NON commité, ignoré par git).
# AUCUNE valeur par défaut n'est utilisée : toute variable requise mais absente
# provoque une erreur explicite au démarrage. L'application est AGNOSTIQUE du
# fournisseur (via Instructor) : pour en changer, on modifie LLM_MODEL + LLM_API_KEY,
# sans toucher au code.

# Backend LLM (OBLIGATOIRE) : "ollama" (local, GPU recommandé) ou "api" (distant).
LLM_BACKEND=api

# --- Les variables ci-dessous sont OBLIGATOIRES si LLM_BACKEND=api ---

# Modèle au format Instructor « fournisseur/modèle » — ce préfixe désigne le
# fournisseur (le code l'ignore) :
#   Anthropic : anthropic/claude-haiku-4-5
#   OpenAI    : openai/gpt-4.1-mini
#   Gemini    : google/gemini-3.1-flash-lite   (⚠ préfixe « google/ », pas « gemini/ »)
#   Mistral   : mistral/mistral-small-latest
LLM_MODEL=google/gemini-3.1-flash-lite

# Clé d'API du fournisseur choisi ci-dessus.
LLM_API_KEY=

# Plafond de tokens générés par jugement (la réponse JSON est courte).
LLM_MAX_TOKENS=1024

# Jugements menés en parallèle. Le téléchargement des annonces reste séquentiel
# (anti-DataDome) ; seul l'appel au LLM est parallélisé.
LLM_CONCURRENCY=6

# Débit MAX autorisé par ton offre, en requêtes/minute. L'app espace les départs
# (60/LLM_RPM s) pour ne JAMAIS le dépasser → aucun 429.
#   Ex. palier gratuit Gemini = 15. Le débit effectif est borné par cette valeur,
#   quelle que soit LLM_CONCURRENCY.
LLM_RPM=15
